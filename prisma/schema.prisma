generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // Connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // Direct connection
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("JUNIOR") // ADMIN, SENIOR, JUNIOR, TRAINEE, INTERN, SITE_SUPERVISOR, SITE_ENGINEER, NON_TECHNICAL
  phone        String?
  skills       String?
  avatar       String?
  // Profile Details
  designation  String?
  fathersName  String?
  joiningDate  DateTime?
  panCard          String?
  aadharNo         String?
  leaveAdjustment  Int      @default(0) // manually added pre-consumed leaves (for mid-year onboarding)
  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances              Attendance[]
  reports                  Report[]
  leaves                   Leave[]
  ownedProjects            Project[]              @relation("ProjectOwner")
  projectMembers           ProjectMember[]
  documents                Document[]
  signedReports            Report[]               @relation("ReportSignOff")
  approvedLeaves           Leave[]                @relation("LeaveApprover")
  notifications            Notification[]
  siteVisits               SiteVisit[]
  salarySlips              SalarySlip[]
  assignedMilestones       Milestone[]            @relation("MilestoneAssignee")
  reviewedMilestones       Milestone[]            @relation("MilestoneReviewer")
  shortLeaves              ShortLeaveRequest[]    @relation("UserShortLeaves")
  approvedShortLeaves      ShortLeaveRequest[]    @relation("ApprovedShortLeaves")
  salaryStructure          SalaryStructure?
  dailySiteLogs            DailySiteLog[]
  employeeOfMonthAwards    EmployeeOfTheMonth[]   @relation("EOMWinner")
  employeeOfMonthGranted   EmployeeOfTheMonth[]   @relation("EOMGrantedBy")
  notices                  Notice[]               @relation("NoticeAuthor")
  noticeReads              NoticeRead[]
}

model EmployeeOfTheMonth {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("EOMWinner", fields: [userId], references: [id])
  month       Int      // 1-12
  year        Int
  reason      String?
  grantedById String
  grantedBy   User     @relation("EOMGrantedBy", fields: [grantedById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([month, year])
}

model Attendance {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  date             DateTime  @default(now())
  checkIn          DateTime  @default(now())
  checkOut         DateTime?
  latitude         Float?
  longitude        Float?
  address          String?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  checkOutAddress   String?
  reportSubmitted  Boolean   @default(false)
  checkoutAttempts Int       @default(0)
  createdAt        DateTime  @default(now())

  reports Report[]
}

model Report {
  id             String     @id @default(cuid())
  attendanceId   String
  attendance     Attendance @relation(fields: [attendanceId], references: [id])
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  projectId      String? // New: Optional linking to a Project
  project        Project?   @relation(fields: [projectId], references: [id])
  tasks          String
  blockers       String?
  nextPlan       String?
  imageUrl       String? // New: Optional image upload (base64 or path)
  submittedAt    DateTime   @default(now())
  managerComment String?
  signedOffBy    String?
  signedOffUser  User?      @relation("ReportSignOff", fields: [signedOffBy], references: [id])
  createdAt      DateTime   @default(now())
}

model Leave {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String   @default("FULL") // FULL, HALF, CUSTOM
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy String?
  approver   User?    @relation("LeaveApprover", fields: [approvedBy], references: [id])
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  name         String
  client       String
  startDate    DateTime
  endDate      DateTime?
  description  String?
  status       String    @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  location     String?
  latitude     Float?
  longitude    Float?
  contactName  String?
  contactPhone String?
  contactEmail String?
  ownerId      String
  owner        User      @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members       ProjectMember[]
  documents     Document[]
  reports       Report[]
  siteVisits    SiteVisit[]
  milestones    Milestone[]
  dailySiteLogs DailySiteLog[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  role      String  @default("MEMBER") // LEAD, MEMBER

  @@unique([projectId, userId])
}

model Document {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  storagePath String
  version     Int      @default(1)
  uploadedBy  String
  uploader    User     @relation(fields: [uploadedBy], references: [id])
  tags        String? // JSON stringified array
  mimeType    String?
  size        Int?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String // Admin who receives it
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model SiteVisit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  latitude  Float?
  longitude Float?
  address   String?
  purpose   String?  @default("Site Visit") // Survey, Meeting, Inspection, Audit
  notes     String
  photoUrls String? // JSON stringified array of base64 strings
  status    String   @default("PENDING") // PENDING, REVIEWED
  createdAt DateTime @default(now())
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  sequence    Int       @default(0)
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?     @relation("MilestoneAssignee", fields: [assigneeId], references: [id])
  reviewerId  String?
  reviewer    User?     @relation("MilestoneReviewer", fields: [reviewerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


model ShortLeaveRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserShortLeaves", fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  hoursRequested Float
  reason         String
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById   String?
  approvedBy     User?    @relation("ApprovedShortLeaves", fields: [approvedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SalaryStructure {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  basicSalary         Float    @default(0)
  hraRate             Float    @default(50) // Percentage of basic
  daRate              Float    @default(10) // Percentage of basic
  
  medicalAllowance    Float    @default(0)
  mobileAllowance     Float    @default(0)
  travelAllowance     Float    @default(0)
  seniorityAllowance  Float    @default(0)
  
  annualIncentiveRate Float    @default(5) // Percentage of basic
  annualIncentiveMonth String? // e.g. "January"
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SalarySlip {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  month               String   // e.g. "October"
  year                Int      // e.g. 2025
  
  allowedLeaves       Float    @default(0)
  balanceLeaves       Float    @default(0)
  excessLeaves        Float    @default(0)
  
  basicSalary         Float
  houseRentAllowance  Float
  dearnessAllowance   Float
  medicalAllowance    Float
  mobileAllowance     Float
  travelAllowance     Float
  seniorityAllowance  Float
  leaveAllowance      Float    @default(0)
  annualIncentive     Float    @default(0)
  advanceDeduction    Float    @default(0)
  
  grossSalary         Float
  
  status              String   @default("GENERATED") // GENERATED, PAID
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@unique([userId, month, year])
}

model Notice {
  id           String       @id @default(cuid())
  title        String
  message      String
  priority     String       @default("NORMAL") // NORMAL, URGENT, INFO
  postedById   String
  postedBy     User         @relation("NoticeAuthor", fields: [postedById], references: [id])
  whatsappSent Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reads        NoticeRead[]
}

model NoticeRead {
  id        String   @id @default(cuid())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([noticeId, userId])
}

model DailySiteLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  masonCount  Int      @default(0)
  coolieCount Int      @default(0)
  helperCount Int      @default(0)
  notes       String?
  mediaUrls   String?  // JSON array of base64 image/video strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, projectId, date])
}
