generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DB_PRISMA_URL")
  directUrl = env("DB_URL_NON_POOLING")
}

model User {
  id                     String               @id @default(cuid())
  name                   String
  email                  String               @unique
  passwordHash           String
  role                   String               @default("JUNIOR")
  phone                  String?
  skills                 String?
  avatar                 String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  aadharNo               String?
  designation            String?
  fathersName            String?
  joiningDate            DateTime?
  panCard                String?
  leaveAdjustment        Int                  @default(0)
  attendances            Attendance[]
  dailySiteLogs          DailySiteLog[]
  documents              Document[]
  employeeOfMonthGranted EmployeeOfTheMonth[] @relation("EOMGrantedBy")
  employeeOfMonthAwards  EmployeeOfTheMonth[] @relation("EOMWinner")
  approvedLeaves         Leave[]              @relation("LeaveApprover")
  leaves                 Leave[]
  assignedMilestones     Milestone[]          @relation("MilestoneAssignee")
  reviewedMilestones     Milestone[]          @relation("MilestoneReviewer")
  milestoneComments      MilestoneComment[]
  notices                Notice[]             @relation("NoticeAuthor")
  noticeReads            NoticeRead[]
  notifications          Notification[]
  ownedProjects          Project[]            @relation("ProjectOwner")
  managedProjects        Project[]            @relation("ProjectManager")
  projectMembers         ProjectMember[]
  signedReports          Report[]             @relation("ReportSignOff")
  reports                Report[]
  salarySlips            SalarySlip[]
  salaryStructure        SalaryStructure?
  approvedShortLeaves    ShortLeaveRequest[]  @relation("ApprovedShortLeaves")
  shortLeaves            ShortLeaveRequest[]  @relation("UserShortLeaves")
  siteVisits             SiteVisit[]
}

model EmployeeOfTheMonth {
  id          String   @id @default(cuid())
  userId      String
  month       Int
  year        Int
  reason      String?
  grantedById String
  createdAt   DateTime @default(now())
  grantedBy   User?    @relation("EOMGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  user        User     @relation("EOMWinner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([month, year])
}

model Attendance {
  id                String    @id @default(cuid())
  userId            String
  date              DateTime  @default(now())
  checkIn           DateTime  @default(now())
  checkOut          DateTime?
  reportSubmitted   Boolean   @default(false)
  checkoutAttempts  Int       @default(0)
  createdAt         DateTime  @default(now())
  address           String?
  latitude          Float?
  longitude         Float?
  checkOutAddress   String?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports           Report[]
}

model Report {
  id             String     @id @default(cuid())
  attendanceId   String
  userId         String
  projectId      String?
  tasks          String
  blockers       String?
  nextPlan       String?
  imageUrl       String?
  submittedAt    DateTime   @default(now())
  managerComment String?
  signedOffBy    String?
  createdAt      DateTime   @default(now())
  attendance     Attendance @relation(fields: [attendanceId], references: [id])
  project        Project?   @relation(fields: [projectId], references: [id])
  signedOffUser  User?      @relation("ReportSignOff", fields: [signedOffBy], references: [id], onDelete: SetNull)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leave {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("FULL")
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("PENDING")
  approvedBy String?
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  approver   User?    @relation("LeaveApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id               String          @id @default(cuid())
  name             String
  client           String
  startDate        DateTime
  endDate          DateTime?
  description      String?
  status           String          @default("ACTIVE")
  location         String?
  latitude         Float?
  longitude        Float?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  ownerId          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  projectManagerId String?
  dailySiteLogs    DailySiteLog[]
  documents        Document[]
  milestones       Milestone[]
  owner            User?           @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  projectManager   User?           @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  members          ProjectMember[]
  reports          Report[]
  siteVisits       SiteVisit[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String  @default("MEMBER")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Document {
  id          String   @id @default(cuid())
  projectId   String
  filename    String
  storagePath String
  version     Int      @default(1)
  uploadedBy  String
  tags        String?
  mimeType    String?
  size        Int?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader    User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteVisit {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  date      DateTime @default(now())
  latitude  Float?
  longitude Float?
  address   String?
  notes     String
  photoUrls String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  purpose   String?  @default("Site Visit")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id              String             @id @default(cuid())
  projectId       String
  title           String
  description     String?
  status          String             @default("TODO")
  sequence        Int                @default(0)
  dueDate         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  assigneeId      String?
  reviewerId      String?
  deliverableName String?
  deliverableType String?
  deliverableUrl  String?
  assignee        User?              @relation("MilestoneAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer        User?              @relation("MilestoneReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  comments        MilestoneComment[]
}

model MilestoneComment {
  id          String    @id @default(cuid())
  milestoneId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShortLeaveRequest {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  hoursRequested Float
  reason         String
  status         String   @default("PENDING")
  approvedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  approvedBy     User?    @relation("ApprovedShortLeaves", fields: [approvedById], references: [id])
  user           User     @relation("UserShortLeaves", fields: [userId], references: [id], onDelete: Cascade)
}

model SalaryStructure {
  id                   String   @id @default(cuid())
  userId               String   @unique
  basicSalary          Float    @default(0)
  hraRate              Float    @default(50)
  daRate               Float    @default(10)
  medicalAllowance     Float    @default(0)
  mobileAllowance      Float    @default(0)
  travelAllowance      Float    @default(0)
  seniorityAllowance   Float    @default(0)
  annualIncentiveRate  Float    @default(5)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  annualIncentiveMonth String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalarySlip {
  id                 String   @id @default(cuid())
  userId             String
  status             String   @default("GENERATED")
  createdAt          DateTime @default(now())
  advanceDeduction   Float    @default(0)
  allowedLeaves      Float    @default(0)
  annualIncentive    Float    @default(0)
  balanceLeaves      Float    @default(0)
  basicSalary        Float
  dearnessAllowance  Float
  excessLeaves       Float    @default(0)
  grossSalary        Float
  houseRentAllowance Float
  leaveAllowance     Float    @default(0)
  medicalAllowance   Float
  mobileAllowance    Float
  month              String
  seniorityAllowance Float
  travelAllowance    Float
  updatedAt          DateTime @updatedAt
  year               Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model Notice {
  id           String       @id @default(cuid())
  title        String
  message      String
  priority     String       @default("NORMAL")
  postedById   String
  whatsappSent Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  postedBy     User         @relation("NoticeAuthor", fields: [postedById], references: [id])
  reads        NoticeRead[]
}

model NoticeRead {
  id       String   @id @default(cuid())
  noticeId String
  userId   String
  readAt   DateTime @default(now())
  notice   Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
}

model DailySiteLog {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  date        DateTime @db.Date
  notes       String?
  mediaUrls   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  coolieCount Int      @default(0)
  helperCount Int      @default(0)
  masonCount  Int      @default(0)
  otherCount  Int      @default(0)
  audioUrl    String?
  address     String?
  latitude    Float?
  longitude   Float?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, date])
}
